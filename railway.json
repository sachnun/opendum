{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "RAILPACK",
        "buildCommand": "pnpm --filter @opendum/shared build && pnpm --filter @opendum/proxy build",
        "watchPatterns": [
            "apps/proxy/**",
            "packages/shared/**",
            "package.json",
            "pnpm-lock.yaml",
            "pnpm-workspace.yaml",
            "tsconfig.base.json",
            "railway.json"
        ]
    },
    "deploy": {
        "startCommand": "node apps/proxy/dist/server.js",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 10,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}