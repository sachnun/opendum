# Opendum Monorepo — Root .env.example
#
# For development, copy this file to .env at the root.
# Each app (apps/dashboard, apps/proxy) will read from the root .env
# or you can create separate .env files in each app directory.
#
# See also:
#   apps/dashboard/.env.example — Dashboard-specific variables
#   apps/proxy/.env.example     — Proxy-specific variables

# Database (PostgreSQL — optional, falls back to local PGlite in dashboard)
# DATABASE_URL="postgresql://user:password@localhost:5432/opendum"

# Better Auth (dashboard only)
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-characters-long"

# Encryption (shared between dashboard and proxy — MUST be the same key)
# ENCRYPTION_SECRET="your-encryption-key-at-least-32-characters-long"

# GitHub OAuth (dashboard only)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth (dashboard only)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Redis (optional — defaults to in-memory mock)
# REDIS_URL="redis://default:password@localhost:6379"

# Flags SDK (dashboard only)
FLAGS_SECRET="your-flags-secret-32-bytes-base64url"

# Proxy URL (dashboard playground uses this to call proxy)
NEXT_PUBLIC_PROXY_URL="http://localhost:4000"
