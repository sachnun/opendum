# Step 1: copy this file
# cp .env.example .env

# Step 2: Database (PostgreSQL — optional, falls back to local PGlite)
# DATABASE_URL="postgresql://user:password@localhost:5432/opendum"

# Step 3: Better Auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-characters-long"

# Step 3b: Encryption (optional, falls back to BETTER_AUTH_SECRET)
# ENCRYPTION_SECRET="your-encryption-key-at-least-32-characters-long"

# Step 4: GitHub OAuth
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Step 5: Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Step 6: Redis (optional — defaults to in-memory mock via ioredis-mock)
# REDIS_URL="redis://default:password@localhost:6379"
