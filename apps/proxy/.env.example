# Proxy Environment Variables

# Database (PostgreSQL — required)
DATABASE_URL="postgresql://user:password@localhost:5432/opendum"

# Encryption (must match dashboard's encryption key)
ENCRYPTION_SECRET="your-encryption-key-at-least-32-characters-long"

# Redis (optional — defaults to in-memory mock via ioredis-mock)
# REDIS_URL="redis://default:password@localhost:6379"

# Server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# CORS (set to your dashboard URL in production)
CORS_ORIGIN="http://localhost:3000"

# Dashboard URL (for redirects)
DASHBOARD_URL="http://localhost:3000"
