# Dashboard Environment Variables

# Database (PostgreSQL — optional, falls back to local PGlite)
# DATABASE_URL="postgresql://user:password@localhost:5432/opendum"

# Better Auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-characters-long"

# Encryption (optional, falls back to BETTER_AUTH_SECRET)
# ENCRYPTION_SECRET="your-encryption-key-at-least-32-characters-long"

# GitHub OAuth
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Redis (optional — defaults to in-memory mock via ioredis-mock)
# REDIS_URL="redis://default:password@localhost:6379"

# Flags SDK (required for maintenance mode / feature flags)
FLAGS_SECRET="your-flags-secret-32-bytes-base64url"

# Proxy URL (for playground to call the proxy service)
NEXT_PUBLIC_PROXY_URL="http://localhost:4000"
