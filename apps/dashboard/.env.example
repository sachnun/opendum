# Railway service: dashboard
# Config file: /railway/dashboard.json

# Core services
# Railway Postgres URL for the shared app database.
DATABASE_URL=""
# Railway Redis URL used by dashboard caches and quota snapshots.
REDIS_URL=""

# Auth/app URLs
# Public URL of the deployed dashboard service.
BETTER_AUTH_URL=""
# Shared secret used for Better Auth and encrypted provider data.
BETTER_AUTH_SECRET=""
# Public URL of the proxy service, exposed to the browser.
NEXT_PUBLIC_PROXY_URL=""

# GitHub OAuth
# Callback URL: https://xxxx/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth
# Callback URL: https://xxxx/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
