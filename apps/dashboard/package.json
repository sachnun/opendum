    "better-auth": "^1.5.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.4.2",
    "trpc-nuxt": "^2.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.94",
    "@nuxt/eslint": "^1.15.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.7"
