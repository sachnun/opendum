    "drizzle-orm": "^0.45.1",
    "fast-fuzzy": "^1.12.0",
    "ioredis": "^5.10.1",
    "nuxt": "^4.4.2",
    "pg": "^8.16.3",
    "smol-toml": "^1.6.0",
    "trpc-nuxt": "^2.0.2",
    "zod": "^4.3.6"
