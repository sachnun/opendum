        "low": "low",
        "medium": "medium",
        "none": "minimal",
        "xhigh": "high"
      }
    },
    "copilot": {
      "allowedTiers": [
        "pro",
        "pro+",
        "business",
        "enterprise"
      ],
      "reasoning_effort": false
    },
    "gemini_cli": {
      "upstream": "gemini-3-flash"
    }
