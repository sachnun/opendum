{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "scripts": {
      "entry": [
        "scripts/models.mjs"
      ],
      "project": [
        "scripts/**/*.mjs"
      ]
    },
    "apps/dashboard": {
      "entry": [
        "components.json",
        "app/app.vue",
        "app/error.vue",
        "app/middleware/auth.ts",
        "server/api/**/*.ts",
        "server/services/**/*.ts",
        "server/lib/**/*.ts",
        "server/utils/**/*.ts",
        "app/composables/**/*.ts",
        "app/components/**/*.vue",
        "app/pages/**/*.vue",
        "app/layouts/**/*.vue",
        "app/utils/**/*.ts",
        "types/model-registry.d.ts"
      ],
      "project": [
        "app/**/*.{ts,vue}",
        "lib/**/*.ts",
        "server/**/*.ts",
        "types/**/*.d.ts"
      ]
    },
    "apps/proxy": {
      "entry": [
        "cmd/proxy/main.go"
      ],
      "project": [
        "**/*.go"
      ]
    }
  },
  "ignore": [
    "scripts/lib/shared.mjs",
    "scripts/lib/clean-key.mjs",
    "scripts/model-registry.mjs",
    "scripts/antigravity-models.mjs",
    "scripts/antigravity-version.mjs",
    "scripts/cloudflare.mjs",
    "scripts/codex.mjs",
    "scripts/copilot.mjs",
    "scripts/kiro.mjs",
    "scripts/opencode.mjs",
    "scripts/openrouter.mjs",
    "scripts/siliconflow.mjs",
    "scripts/zenmux.mjs",
    "scripts/nvidia.mjs",
    "scripts/kilo-code.mjs",
    "apps/dashboard/lib/dashboard-api-types.ts",
    "apps/dashboard/lib/model-families.ts",
    "apps/dashboard/lib/provider-accounts.ts",
    "apps/dashboard/server/lib/proxy/loader.ts",
    "apps/dashboard/server/lib/providers/antigravity/quota.ts",
    "apps/dashboard/server/lib/providers/copilot/index.ts",
    "apps/dashboard/server/lib/providers/copilot/client.ts",
    "apps/dashboard/server/lib/providers/copilot/constants.ts"
  ],
  "ignoreBinaries": ["go"],
  "ignoreDependencies": ["vue-tsc"]
}


