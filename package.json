{
  "name": "opendum",
  "version": "0.2.0",
  "private": true,
  "packageManager": "npm@11.14.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev --workspace @opendum/dashboard",
    "dev:proxy": "TOKEN_REFRESH_INTERVAL_SECONDS=0 go -C apps/proxy run ./cmd/proxy",
    "dev": "(npm run dev:dashboard & npm run dev:proxy)",
    "build:dashboard": "npm run build --workspace @opendum/dashboard",
    "build:proxy": "go -C apps/proxy build ./...",
    "build": "npm run build:dashboard && npm run build:proxy",
    "db:push": "npm run db:push --workspace @opendum/dashboard",
    "db:studio": "npm run db:studio --workspace @opendum/dashboard",
    "lint": "npm run lint --workspace @opendum/dashboard && go -C apps/proxy test ./...",
    "models:refresh": "node scripts/models.mjs"
  },
  "devDependencies": {
    "edgeone": "^1.6.9",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.16",
    "typescript-eslint": "^8.62.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1"
  }
}
