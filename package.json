{
  "name": "opendum",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:dashboard": "bun run --cwd apps/dashboard dev",
    "dev:proxy": "TOKEN_REFRESH_INTERVAL_SECONDS=0 go -C apps/proxy run ./cmd/proxy",
    "dev": "(bun run dev:dashboard & bun run dev:proxy)",
    "build:dashboard": "bun run --cwd apps/dashboard build",
    "build:proxy": "go -C apps/proxy build ./...",
    "build": "bun run build:dashboard && bun run build:proxy",
    "db:push": "bun run --cwd apps/dashboard db:push",
    "db:studio": "bun run --cwd apps/dashboard db:studio",
    "lint": "bun run --cwd apps/dashboard lint && go -C apps/proxy test ./...",
    "models:refresh": "bun scripts/models.mjs"
  },
  "devDependencies": {
    "edgeone": "^1.6.13",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.16",
    "typescript-eslint": "^8.62.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1"
  }
}
