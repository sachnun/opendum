{
  "name": "opendum",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev:dashboard": "pnpm --filter @opendum/dashboard dev",
    "dev:proxy": "pnpm --filter @opendum/proxy dev",
    "dev": "pnpm --filter @opendum/shared build && pnpm --parallel --filter @opendum/dashboard --filter @opendum/proxy dev",
    "clean": "pnpm -r exec rm -rf dist .next tsconfig.tsbuildinfo",
    "build:shared": "pnpm --filter @opendum/shared build",
    "build:dashboard": "pnpm --filter @opendum/dashboard... build",
    "build:proxy": "pnpm --filter @opendum/proxy... build",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "db:push": "pnpm --filter @opendum/dashboard db:push",
    "db:studio": "pnpm --filter @opendum/dashboard db:studio",
    "lint": "pnpm --filter @opendum/shared build && pnpm --filter @opendum/dashboard lint && pnpm --filter @opendum/proxy lint",
    "models:refresh": "node scripts/models.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
