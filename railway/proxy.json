{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "pnpm --filter @opendum/shared build && pnpm --filter @opendum/proxy build",
    "watchPatterns": [
      "apps/proxy/**",
      "packages/shared/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway/proxy.json"
    ]
  },
  "deploy": {
    "startCommand": "node apps/proxy/dist/server.js"
  }
}
