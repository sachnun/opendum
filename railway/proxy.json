{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "mkdir -p dist && cd apps/proxy && go build -o ../../dist/proxy ./cmd/proxy",
    "watchPatterns": [
      "apps/proxy/**",
      "models/**",
      "package.json",
      "railway/proxy.json"
    ]
  },
  "deploy": {
    "startCommand": "./dist/proxy"
  }
}
