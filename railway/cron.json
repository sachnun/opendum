{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "pnpm --filter @opendum/dashboard build:cron",
    "watchPatterns": [
      "apps/dashboard/server/lib/**",
      "apps/dashboard/package.json",
      "models/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway/cron.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @opendum/dashboard cron",
    "cronSchedule": "0 */6 * * *"
  }
}
