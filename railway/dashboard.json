{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "pnpm --filter @opendum/dashboard build",
    "watchPatterns": [
      "apps/dashboard/**",
      "packages/shared/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway/dashboard.json"
    ]
  },
  "deploy": {
    "startCommand": "HOSTNAME=0.0.0.0 node apps/dashboard/.next/standalone/apps/dashboard/server.js"
  }
}
