{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @opendum/dashboard build",
    "watchPatterns": [
      "apps/dashboard/**",
      "packages/shared/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway/dashboard.json"
    ]
  },
  "deploy": {
    "startCommand": "node apps/dashboard/.next/standalone/apps/dashboard/server.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 20,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
